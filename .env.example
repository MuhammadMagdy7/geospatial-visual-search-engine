# Database
POSTGRES_USER=gvs_user
POSTGRES_PASSWORD=gvs_password_2024
POSTGRES_DB=geospatial_visual_search
DATABASE_URL=postgresql+asyncpg://gvs_user:gvs_password_2024@db:5432/geospatial_visual_search

# External APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:8000
VITE_MAP_STYLE=https://demotiles.maplibre.org/style.json

# ML Model
MODEL_DEVICE=cpu

# HuggingFace offline mode
# Set to "0" ONLY on the very first run to allow initial model download.
# After the model is cached in the hf_cache volume, set back to "1" (or unset).
# Default is "1" (fully offline) which is the recommended production value.
TRANSFORMERS_OFFLINE=1
